    "better-sqlite3": "^12.8.0",
    "eventemitter3": "^5.0.4",
    "fastify": "^5.8.4",
    "gray-matter": "^4.0.3",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
