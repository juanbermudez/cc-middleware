{
  "name": "cc-middleware",
  "version": "0.1.0",
  "description": "Middleware for managing and observing Claude Code sessions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ccm": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./api": {
      "import": "./dist/api/server.js",
      "types": "./dist/api/server.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/event-bus.js",
      "types": "./dist/hooks/event-bus.d.ts"
    },
    "./sessions": {
      "import": "./dist/sessions/manager.js",
      "types": "./dist/sessions/manager.d.ts"
    },
    "./store": {
      "import": "./dist/store/db.js",
      "types": "./dist/store/db.d.ts"
    },
    "./config": {
      "import": "./dist/config/settings.js",
      "types": "./dist/config/settings.d.ts"
    },
    "./permissions": {
      "import": "./dist/permissions/policy.js",
      "types": "./dist/permissions/policy.d.ts"
    },
    "./agents": {
      "import": "./dist/agents/registry.js",
      "types": "./dist/agents/registry.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "start": "node dist/main.js",
    "ccm": "node dist/cli/index.js",
    "render-diagrams": "tsx scripts/render-diagrams.ts",
    "docs:dev": "cd docs-site && npx --yes mint dev",
    "validate:openapi": "npx @redocly/cli lint docs-site/openapi.json",
    "validate:asyncapi": "npx @asyncapi/cli validate docs-site/asyncapi.json",
    "docs:validate": "npm run render-diagrams && cd docs-site && npx --yes mint validate",
    "docs:build": "npm run docs:validate"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.92",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "beautiful-mermaid": "^1.1.3",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "eventemitter3": "^5.0.4",
    "fastify": "^5.8.4",
    "gray-matter": "^4.0.3",
    "ora": "^9.3.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
