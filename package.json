{
  "name": "cc-middleware",
  "version": "0.1.0",
  "description": "Middleware for managing and observing Claude Code sessions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
